{
  "name": "sunset-pulse-monorepo",
  "private": true,
  "workspaces": [
    "apps/pulse",
    "apps/scheduling/web",
    "apps/api/v2",
    "packages/*",
    "packages/app-store/*",
    "packages/embeds/*",
    "packages/features/*",
    "packages/platform/*",
    "packages/platform/examples/*"
  ],
  "scripts": {
    "pulse:dev": "npm run dev --workspace=apps/pulse",
    "pulse:build": "npm run generate-schemas --workspace=@calcom/prisma && npm run build --workspace=apps/pulse",
    "tah:dev": "dotnet watch --project apps/WorldofTah run",
    "scheduling:dev": "npm run dev --workspace=apps/scheduling/web",
    "scheduling:build": "npm run build --workspace=apps/scheduling/web",
    "tah:import-doc": "tsx apps/pulse/scripts/import-doc-to-tah.ts",
    "tah:lancedb:index": "tsx apps/pulse/scripts/tah-lancedb.ts",
    "tah:lancedb:search": "tsx apps/pulse/scripts/tah-lancedb-search.ts",
    "openresync:up": "docker compose --env-file infra/openresync/.env -f infra/openresync/compose.yaml up -d --build",
    "openresync:down": "docker compose --env-file infra/openresync/.env -f infra/openresync/compose.yaml down",
    "openresync:doctor": "npm run mls:openresync:doctor --workspace=apps/pulse",
    "openresync:normalize": "npm run mls:openresync:normalize --workspace=apps/pulse",
    "security:audit:prod": "npm audit --omit=dev --audit-level=low",
    "security:audit:pulse": "npm audit --workspace property-pulse --omit=dev --audit-level=high",
    "test:unit": "npm run test:unit --workspace=apps/pulse",
    "test:e2e": "npm run test:e2e --workspace=apps/pulse"
  },
  "devDependencies": {
    "next": "^15.5.16",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^15.12.0"
  },
  "optionalDependencies": {
    "@depot/cli-linux-x64": "0.0.1-cli.2.80.0",
    "@rollup/rollup-linux-x64-gnu": "4.60.3",
    "@rollup/rollup-linux-x64-musl": "4.60.3"
  },
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@calcom/web": {
      "react": "18.2.0",
      "react-dom": "18.2.0"
    },
    "@hono/node-server": "2.0.3",
    "@babel/core": "7.29.7",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@nestjs/platform-express": {
      "express": "5.2.1",
      "multer": "2.2.0"
    },
    "@opentelemetry/core": "2.8.0",
    "@opentelemetry/exporter-logs-otlp-http": "0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.219.0",
    "@opentelemetry/otlp-exporter-base": "0.219.0",
    "@opentelemetry/otlp-transformer": "0.219.0",
    "@opentelemetry/resources": "2.8.0",
    "@opentelemetry/sdk-logs": "0.219.0",
    "@opentelemetry/sdk-metrics": "2.8.0",
    "@opentelemetry/sdk-trace-base": "2.8.0",
    "@protobufjs/utf8": "1.1.1",
    "axios": "1.18.1",
    "body-parser": {
      "qs": "6.15.3"
    },
    "brace-expansion": "2.1.0",
    "cookie": "1.1.1",
    "defu": "6.1.7",
    "dompurify": "3.4.11",
    "effect": "3.21.2",
    "esbuild": "0.28.1",
    "fast-uri": "3.1.2",
    "fast-xml-parser": "5.8.0",
    "file-type": "22.0.1",
    "follow-redirects": "1.16.0",
    "form-data": "4.0.6",
    "glob": "10.5.0",
    "google-auth-library": "10.5.0",
    "googleapis-common": {
      ".": "8.0.2",
      "google-auth-library": "10.5.0"
    },
    "hono": "4.12.27",
    "js-cookie": "3.0.7",
    "js-yaml": "4.3.0",
    "jsondiffpatch": "0.7.2",
    "lodash": "4.18.1",
    "lodash-es": "4.18.1",
    "markdown-it": "14.3.0",
    "minimatch": "9.0.9",
    "nanoid": "3.3.11",
    "next-auth": {
      "nodemailer": "9.0.3"
    },
    "next": {
      "postcss": "8.5.16"
    },
    "node-forge": "1.4.0",
    "nodemailer": "9.0.3",
    "phin": "3.7.1",
    "picomatch": "2.3.2",
    "postcss": "8.5.16",
    "protobufjs": "7.6.4",
    "protocol-buffers-schema": "3.6.1",
    "qs": "6.15.3",
    "shell-quote": "1.9.0",
    "systeminformation": "5.31.6",
    "tar": "7.5.19",
    "tmp": "0.2.5",
    "uuid": "11.1.1",
    "ws": "8.21.0",
    "yaml": "2.9.0"
  }
}
