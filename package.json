{
  "name": "sunset-pulse-monorepo",
  "private": true,
  "workspaces": [
    "apps/pulse",
    "apps/scheduling/web",
    "apps/api/v2",
    "packages/*",
    "packages/app-store/*",
    "packages/features/*",
    "packages/platform/*",
    "packages/platform/examples/*"
  ],
  "scripts": {
