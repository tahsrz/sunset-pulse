    "axios": "1.16.1",
    "brace-expansion": "2.1.0",
    "cookie": "1.1.1",
    "defu": "6.1.7",
    "dompurify": "3.4.5",
    "effect": "3.21.2",
    "esbuild": "0.28.0",
    "fast-uri": "3.1.2",
    "fast-xml-parser": "5.8.0",
    "file-type": "22.0.1",
    "follow-redirects": "1.16.0",
    "hono": "4.12.22",
    "js-cookie": "3.0.7",
    "js-yaml": "4.1.1",
