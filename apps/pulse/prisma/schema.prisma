datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

model User {
  id              Int              @id @default(autoincrement())
  username        String?
  name            String?
  email           String           @unique
  timeZone        String           @default("America/Chicago")
  metadata        Json?
  bookings        Booking[]
  verifiedNumbers VerifiedNumber[]
  smsShiftOffers  SmsShiftOffer[]

  @@index([email])
}

model VerifiedNumber {
  id          Int     @id @default(autoincrement())
  userId      Int
  phoneNumber String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phoneNumber])
  @@index([userId])
}

model EventType {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String
  description String?
  length      Int
  bookings    Booking[]

  @@index([slug])
}

model Attendee {
  id          Int      @id @default(autoincrement())
  email       String
  name        String?
  timeZone    String?
  phoneNumber String?
  bookingId   Int
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([email])
}

model Booking {
  id               Int              @id @default(autoincrement())
  uid              String           @unique
  title            String
  description      String?
  startTime        DateTime
  endTime          DateTime
  status           String
  userId           Int?
  eventTypeId      Int?
  userPrimaryEmail String?
  idempotencyKey   String?          @unique
  metadata         Json?
  user             User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  eventType        EventType?       @relation(fields: [eventTypeId], references: [id], onDelete: SetNull)
  attendees        Attendee[]
  smsShiftOffers   SmsShiftOffer[]
  shiftEscalation  ShiftEscalation?

  @@index([startTime])
  @@index([endTime])
  @@index([status])
  @@index([userId])
  @@index([eventTypeId])
}

model SmsShiftOffer {
  id          String   @id @default(uuid())
  bookingId   Int
  userId      Int
  phoneNumber String
  status      String
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([userId])
  @@index([phoneNumber, status])
}

model ShiftEscalation {
  id                 String   @id @default(uuid())
  bookingId          Int      @unique
  status             String
  currentTier        Int
  nextEscalationTime DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  booking            Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([status])
}
