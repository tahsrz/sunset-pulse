# Provider: bridgeInteractive, trestle, or mlsGrid
OPENRESYNC_PLATFORM=bridgeInteractive
OPENRESYNC_SOURCE_NAME=sunsetPilot

# Examples:
# Bridge: https://api.bridgedataoutput.com/api/v2/OData/<dataset>
# Trestle: https://api-trestle.corelogic.com/trestle/odata
# MLS Grid: https://api.mlsgrid.com/v2
OPENRESYNC_RESOURCE_BASE_URL=
OPENRESYNC_METADATA_URL=

# Bridge / MLS Grid
OPENRESYNC_ACCESS_TOKEN=

# Trestle only
OPENRESYNC_CLIENT_ID=
OPENRESYNC_CLIENT_SECRET=

# Keep the pilot narrow until counts and permissions are verified.
OPENRESYNC_PROPERTY_FILTER=City eq 'Fort Worth'
OPENRESYNC_INCLUDE_MEDIA=true
OPENRESYNC_PAGE_SIZE=100
OPENRESYNC_PURGE_PAGE_SIZE=5000

# Start with manual runs. Enable schedules only after reconciliation is verified.
OPENRESYNC_CRON_ENABLED=false
OPENRESYNC_SYNC_CRON=*/15 * * * *
OPENRESYNC_PURGE_CRON=20 3 * * *
OPENRESYNC_RECONCILE_CRON=40 3 * * 0

OPENRESYNC_MYSQL_PASSWORD=sunset-local-pilot
OPENRESYNC_MYSQL_ROOT_PASSWORD=sunset-local-root
OPENRESYNC_MYSQL_PORT=33033
OPENRESYNC_ADMIN_PORT=4000

# Used by the Sunset normalizer running on the host.
OPENRESYNC_RAW_DATABASE_URL=mysql://openresync:sunset-local-pilot@127.0.0.1:33033/sunset_mls
OPENRESYNC_PROPERTY_TABLE=sunset_Property
OPENRESYNC_MEDIA_TABLE=sunset_Media
OPENRESYNC_NORMALIZE_LIMIT=2000
